{
  "name": "autopilot",
  "version-string": "0.1.0",
  "description": "Windows Automation Suite — Macro + Web Recorder + OCR",
  "homepage": "https://github.com/your-org/autopilot",
  "builtin-baseline": "371d1f7a6c3eb391037e9c2bcddf0bec85675bf1",
  "dependencies": [
    {
      "name": "qtbase",
      "features": ["widgets", "gui"]
    },
