    "tesseract",
    "leptonica",
    {
      "name": "opencv4",
      "features": ["png", "jpeg", "tiff"]
    },
    "spdlog",
    "nlohmann-json",
    "sqlite3",
    "sol2",
    "lua",
    "libwebsockets",
    "gtest"
  ],
  "overrides": [
    { "name": "qtbase", "version": "6.7.2" }
  ]
}
