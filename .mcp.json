{
  "$comment": "ใส่ token จริงผ่าน environment variables ห้ามแก้ค่าตรงในไฟล์นี้ ทุก field ${...} จะถูก resolve จาก env ตอน Claude Code start",
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "C:\\Users\\hello\\Documents\\AutoPilot"
      ]
    }
  }
}
